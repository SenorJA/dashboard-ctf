    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst vulnerabilities = [];\nfor (const item of items) {\n if (item.json.vulnerabilities) {\n const cves = item.json.vulnerabilities.slice(0, 20);\n for (const vuln of cves) {\n const cve = vuln.cve;\n const metrics = cve.metrics?.cvssMetricV31?.[0]?.cvssData || cve.metrics?.cvssMetricV2?.[0]?.cvssData;\n if (metrics && metrics.baseScore >= 4.0) {\n vulnerabilities.push({ source: 'NIST', cve_id: cve.id, description: cve.descriptions?.[0]?.value?.substring(0, 300), cvss_score: metrics.baseScore, severity: metrics.baseSeverity || 'UNKNOWN', published: cve.published, vector: metrics.vectorString });\n }\n }\n }\n if (item.json.data?.search) {\n item.json.data.search.slice(0, 10).forEach(v => {\n if (v.cvss?.score >= 4.0) vulnerabilities.push({ source: 'Vulners', cve_id: v.id, description: v.description?.substring(0, 300), cvss_score: v.cvss.score, severity: v.cvss.score >= 9 ? 'CRITICAL' : v.cvss.score >= 7 ? 'HIGH' : 'MEDIUM', published: v.published });\n });\n }\n if (item.json.vulns) {\n Object.keys(item.json.vulns).forEach(cve => vulnerabilities.push({ source: 'Shodan', cve_id: cve, cvss_score: item.json.vulns[cve].cvss || 5.0, severity: 'MEDIUM', verified: item.json.vulns[cve].verified }));\n }\n if (item.json.pulse_info?.count > 0) vulnerabilities.push({ source: 'AlienVault', threat_score: item.json.pulse_info.count, pulses: item.json.pulse_info.pulses?.slice(0, 5).map(p => p.name) });\n}\nconst unique = Array.from(new Map(vulnerabilities.map(v => [v.cve_id, v])).values());\nreturn [{ json: { vulnerabilities: unique, total_vulns: unique.length } }];"
      },
