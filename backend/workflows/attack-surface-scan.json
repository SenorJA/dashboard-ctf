        "jsCode": "const items = $input.all();\nlet services = [];\nlet subdomains = [];\nlet vulnerabilities = [];\nlet breaches = [];\nlet threatIntel = { abuseipdb: {}, greynoise: {}, alienvault: {}, virustotal: {} };\nlet webFindings = { wordpress: [], sqli: [], directories: [] };\n\nfor (const item of items) {\n const json = item.json;\n if (json.port && json.state === 'open') services.push(json);\n if (json.subdomain) subdomains.push(json.subdomain);\n if (json.vulnerabilities) vulnerabilities = vulnerabilities.concat(json.vulnerabilities);\n if (json.Name && json.BreachDate) breaches.push(json);\n if (json.abuseConfidenceScore) threatIntel.abuseipdb = json;\n if (json.classification) threatIntel.greynoise = json;\n if (json.pulse_info) threatIntel.alienvault = json;\n if (json.data?.attributes) threatIntel.virustotal = json;\n if (json.wordpress_version) webFindings.wordpress.push(json);\n if (json.sqli_vulnerable) webFindings.sqli.push(json);\n if (json.directories) webFindings.directories = json.directories;\n}\n\nconst criticalPorts = [22, 23, 3389, 445, 135, 139, 1433, 3306, 5432];\nconst criticalServices = services.filter(s => criticalPorts.includes(s.port));\nconst criticalVulns = vulnerabilities.filter(v => v.cvss_score >= 9.0);\nconst highVulns = vulnerabilities.filter(v => v.cvss_score >= 7.0 && v.cvss_score < 9.0);\nconst mediumVulns = vulnerabilities.filter(v => v.cvss_score >= 4.0 && v.cvss_score < 7.0);\nconst lowVulns = vulnerabilities.filter(v => v.cvss_score < 4.0);\n\nlet riskScore = 0;\nriskScore += Math.min(30, (criticalServices.length * 10) + (services.length * 0.5));\nriskScore += (criticalVulns.length * 15);\nriskScore += (highVulns.length * 7);\nriskScore += (mediumVulns.length * 2);\nriskScore += (lowVulns.length * 0.5);\nriskScore += Math.min(15, breaches.length * 5);\nif (threatIntel.abuseipdb.abuseConfidenceScore > 75) riskScore += 10;\nelse if (threatIntel.abuseipdb.abuseConfidenceScore > 50) riskScore += 5;\nif (threatIntel.greynoise.classification === 'malicious') riskScore += 10;\nif (threatIntel.alienvault.pulse_info?.count > 10) riskScore += 10;\nelse if (threatIntel.alienvault.pulse_info?.count > 5) riskScore += 5;\nif (webFindings.sqli.length > 0) riskScore += 5;\nif (webFindings.wordpress.some(w => w.outdated)) riskScore += 3;\nriskScore = Math.min(100, Math.round(riskScore));\n\nconst severity = riskScore >= 80 ? 'CRITICAL' : riskScore >= 60 ? 'HIGH' : riskScore >= 40 ? 'MEDIUM' : 'LOW';\nconst timestamp_end = new Date().toISOString();\nconst timestamp_start = items[0]?.json?.timestamp_start || timestamp_end;\nconst duration = Math.round((new Date(timestamp_end) - new Date(timestamp_start)) / 1000);\n\nreturn [{ json: {\n scan_id: items[0]?.json?.scan_id || 'ASM-UNKNOWN',\n target: items[0]?.json?.target || 'unknown',\n timestamp_start, timestamp_end,\n duration_seconds: duration,\n duration_formatted: Math.floor(duration/60)+'m '+duration%60+'s',\n risk_score: riskScore, severity,\n summary: { total_findings: criticalVulns.length + highVulns.length + mediumVulns.length + lowVulns.length + breaches.length + webFindings.sqli.length, critical: criticalVulns.length, high: highVulns.length + webFindings.sqli.length, medium: mediumVulns.length, low: lowVulns.length, info: breaches.length },\n attack_surface: { open_ports: services.length, critical_ports: criticalServices.length, services_detected: services.length, unique_subdomains: [...new Set(subdomains)].length, vulnerabilities_found: vulnerabilities.length, credential_breaches: breaches.length, web_vulnerabilities: webFindings.sqli.length, exposed_directories: webFindings.directories.length },\n top_risks: vulnerabilities.sort((a,b) => (b.cvss_score||0) - (a.cvss_score||0)).slice(0,15).map(v => ({ type:'Vulnerability', source:v.source, severity:v.severity, cve_id:v.cve_id, cvss_score:v.cvss_score, description:v.description, published:v.published })),\n critical_services: criticalServices.map(s => ({ port:s.port, service:s.service, product:s.product, version:s.version, risk:'CRITICAL' })),\n threat_intelligence: { abuse_confidence: threatIntel.abuseipdb.abuseConfidenceScore || 0, grey_noise_classification: threatIntel.greynoise.classification || 'unknown', alienvault_pulses: threatIntel.alienvault.pulse_info?.count || 0, virustotal_detections: threatIntel.virustotal.data?.attributes?.last_analysis_stats?.malicious || 0 },\n credential_exposure: { total_breaches: breaches.length, breaches: breaches.slice(0,10).map(b => ({ name:b.Name, breach_date:b.BreachDate, pwn_count:b.PwnCount, data_classes:b.DataClasses })) },\n web_findings: webFindings,\n services: services,\n subdomains: [...new Set(subdomains)]\n}}];"
      },
